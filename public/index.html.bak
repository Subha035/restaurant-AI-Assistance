<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurant AI Assistant</title>
    <style>
        :root {
            --bg: #091320;
            --surface: rgba(255, 255, 255, 0.1);
            --surface-strong: rgba(255, 255, 255, 0.16);
            --text: #f6f9ff;
            --muted: #a6b1ce;
            --accent: #ffb55b;
            --accent-strong: #ff8c42;
            --accent-soft: rgba(255, 181, 91, 0.16);
            --shadow: 0 30px 90px rgba(0, 0, 0, 0.34);
            --radius: 28px;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: var(--text);
            background: radial-gradient(circle at top left, rgba(255, 181, 91, 0.18), transparent 24%),
                        radial-gradient(circle at 80% 10%, rgba(99, 196, 255, 0.18), transparent 18%),
                        linear-gradient(180deg, #07111e 0%, #08151f 30%, #0a1729 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle at 20% 15%, rgba(255, 255, 255, 0.06), transparent 12%),
                              radial-gradient(circle at 70% 60%, rgba(255, 255, 255, 0.04), transparent 10%);
            pointer-events: none;
        }

        .app-shell {
            width: min(100%, 860px);
            background: rgba(8, 18, 31, 0.95);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            backdrop-filter: blur(20px);
            position: relative;
        }

        .hero {
            display: grid;
            gap: 20px;
            padding: 36px 36px 26px;
            position: relative;
        }

        .hero::after {
            content: '';
            position: absolute;
            right: 32px;
            top: 26px;
            width: 110px;
            height: 110px;
            background: radial-gradient(circle, rgba(255, 140, 66, 0.35), transparent 58%);
            filter: blur(16px);
            z-index: 0;
        }

        .hero-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 20px;
            position: relative;
            z-index: 1;
        }

        .hero-title {
            margin: 0;
            font-size: clamp(2.3rem, 3.4vw, 3.5rem);
            line-height: 1.02;
        }

        .hero-subtitle {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            background: rgba(255, 181, 91, 0.12);
            color: #ffe4b9;
            border-radius: 999px;
            font-weight: 700;
            letter-spacing: 0.02em;
            box-shadow: inset 0 0 0 1px rgba(255, 181, 91, 0.18);
        }

        .hero p {
            margin: 0;
            max-width: 70ch;
            color: var(--muted);
            line-height: 1.8;
            font-size: 1.05rem;
        }

        .hero-actions {
            display: inline-flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-top: 22px;
        }

        .hero-actions a {
            padding: 14px 24px;
            border-radius: 18px;
            background: linear-gradient(135deg, #ffad5d 0%, #ff8c42 100%);
            color: #08101d;
            font-weight: 700;
            text-decoration: none;
            transition: transform 180ms ease, box-shadow 180ms ease;
        }

        .hero-actions a:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 30px rgba(255, 140, 66, 0.18);
        }

        .overview-cards {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
            position: relative;
            z-index: 1;
        }

        .card {
            padding: 20px;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 16px 45px rgba(0, 0, 0, 0.14);
        }

        .card strong {
            display: block;
            margin-bottom: 10px;
            font-size: 1rem;
            color: #f8fcff;
        }

        .card span {
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        .coming-soon-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 10px 0 0;
            padding: 10px 14px;
            border-radius: 16px;
            background: rgba(255, 77, 94, 0.14);
            color: #ffccd5;
            font-weight: 700;
            letter-spacing: 0.02em;
            font-size: 0.93rem;
            border: 1px solid rgba(255, 77, 94, 0.25);
        }

        .wine-section {
            display: grid;
            gap: 16px;
            padding: 22px;
            border-radius: 26px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 18px 50px rgba(0, 0, 0, 0.14);
            grid-template-columns: 1fr;
        }

        .wine-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .wine-title {
            margin: 0;
            font-size: 1.15rem;
            color: #fff;
        }

        .wine-note {
            color: var(--muted);
            font-size: 0.95rem;
        }

        .wine-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 14px;
        }

        .wine-card {
            padding: 18px 16px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .wine-card strong {
            display: block;
            margin-bottom: 8px;
            font-size: 1rem;
            color: #fff;
        }

        .wine-card span {
            color: var(--muted);
            font-size: 0.93rem;
            line-height: 1.65;
        }

        .message-panel {
            display: grid;
            gap: 14px;
            background: rgba(8, 18, 31, 0.94);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 22px 54px rgba(0, 0, 0, 0.24);
            border-radius: 28px;
            padding: 24px 24px 20px;
            min-height: 420px;
            max-width: 920px;
            width: 100%;
            margin: 0 auto;
        }

        .message-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .panel-title {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.01em;
        }

        .panel-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            background: rgba(255, 181, 91, 0.12);
            color: #ffd9b6;
            border-radius: 999px;
            font-size: 0.92rem;
        }

        .message-list {
            display: grid;
            gap: 12px;
            overflow-y: auto;
            max-height: 300px;
            padding-right: 4px;
            padding-left: 2px;
        }

        .message-list::-webkit-resizer {
            display: none;
        }
